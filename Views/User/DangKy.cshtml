@{
    ViewBag.Title = "Đăng ký";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<style>
    .register-wrapper {
        min-height: calc(100vh - 180px);
        display: flex;
        justify-content: center;
        align-items: center;
    }
</style>

<div class="register-wrapper">

    <div class="register-container">

        <div class="register-card">

            <div class="register-header">
                <h3>ĐĂNG KÝ THÀNH VIÊN</h3>
            </div>

            <div class="register-body">

                @if (ViewBag.ThongBao != null)
                {
                    <div class="alert alert-info text-center">
                        @ViewBag.ThongBao
                    </div>
                }

                @using (Html.BeginForm("DangKy", "User"))
                {
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    @Html.Hidden("returnUrl", (string)ViewBag.ReturnUrl)

                    <div class="form-group">
                        <label>Họ tên</label>
                        @Html.TextBox("HoTen", null,
                            new { @class = "form-control", placeholder = "Nhập họ tên" })
                        <span class="text-danger">@ViewData["err1"]</span>
                    </div>

                    <div class="form-group">
                        <label>Tên đăng nhập</label>
                        @Html.TextBox("TenDN", null,
                            new { @class = "form-control", placeholder = "Tên đăng nhập" })
                        <span class="text-danger">@ViewData["err2"]</span>
                    </div>

                    <div class="form-group">
                        <label>Mật khẩu</label>
                        @Html.Password("MatKhau", null,
                            new { @class = "form-control", placeholder = "Mật khẩu" })
                        <span class="text-danger">@ViewData["err3"]</span>
                    </div>

                    <div class="form-group">
                        <label>Nhập lại mật khẩu</label>
                        @Html.Password("MatKhauNL", null,
                            new { @class = "form-control", placeholder = "Nhập lại mật khẩu" })
                        <span class="text-danger">@ViewData["err4"]</span>
                    </div>

                    <div class="form-group">
                        <label>Email</label>
                        @Html.TextBox("Email", null,
                            new { @class = "form-control", type = "email", placeholder = "Email" })
                        <span class="text-danger">@ViewData["err5"]</span>
                    </div>

                    <div class="form-group">
                        <label>Điện thoại</label>
                        @Html.TextBox("DienThoai", null,
                            new { @class = "form-control", placeholder = "Số điện thoại" })
                        <span class="text-danger">@ViewData["err6"]</span>
                    </div>

                    <div class="form-group">
                        <label>Ngày sinh</label>
                        <input type="date"
                               name="NgaySinh"
                               class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>Địa chỉ</label>
                        <input type="text"
                               name="DiaChi"
                               class="form-control"
                               placeholder="Địa chỉ" />
                    </div>

                    <button type="submit"
                            class="btn btn-success btn-register">

                        <span class="glyphicon glyphicon-user"></span>

                        Đăng ký

                    </button>

                    <button type="reset"
                            class="btn btn-default btn-block"
                            style="margin-top:10px;">

                        Xóa thông tin

                    </button>

                    <div class="login-link">

                        Đã có tài khoản?

                        <a href="@Url.Action("DangNhap",
                                             "User",
                                             new { returnUrl = ViewBag.ReturnUrl })">

                            Đăng nhập

                        </a>

                    </div>
                }

            </div>

        </div>

    </div>

</div>