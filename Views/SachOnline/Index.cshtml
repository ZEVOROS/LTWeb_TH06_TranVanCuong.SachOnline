@using TranVanCuong.SachOnline.Models
@using PagedList.Mvc
@model PagedList.PagedList<SACH>

@{
    ViewBag.Title = "TRANG CHỦ";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<h2 class="text-center">SÁCH MỚI</h2>
<hr />

<div class="row text-center">

    @foreach (var sach in Model)
    {
        <div class="col-sm-4 col-md-4 col-lg-4">
            <div class="thumbnail">

                <img src="~/Images/@sach.AnhBia"
                     class="img-rounded imgbook"
                     alt="@sach.TenSach" />

                <div class="caption">

                    <h4 style="min-height:60px;">
                        <a href="@Url.Action("ChiTietSach","SachOnline",
                        new { id = sach.MaSach })">
                            @sach.TenSach
                        </a>
                    </h4>

                    <p>
                        <a href="@Url.Action("ThemGioHang", "GioHang", new { ms = sach.MaSach, url = Request.Url.ToString() })"
                           class="btn btn-primary">
                            Add to Cart
                        </a>
                    </p>

                </div>

            </div>
        </div>
    }

<div class="text-center">
    <p>
        Trang @Model.PageNumber / @Model.PageCount
    </p>

    @Html.PagedListPager(
            Model,
            page => Url.Action(null, new
            {
                id = ViewBag.MaCD,
                page
            }),
            new PagedListRenderOptions
            {
                DisplayLinkToFirstPage = PagedListDisplayMode.Always,
                DisplayLinkToLastPage = PagedListDisplayMode.Always,
                DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                DisplayLinkToNextPage = PagedListDisplayMode.Always,
                MaximumPageNumbersToDisplay = 5
            })
</div>
</div>

@section SachBanNhieu
{
    @Html.Action("SachBanNhieuPartial", "SachOnline")
}