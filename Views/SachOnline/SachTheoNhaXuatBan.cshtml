@model IEnumerable<TranVanCuong.SachOnline.Models.SACH>

@{
    ViewBag.Title = "Sách theo nhà xuất bản";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}
<h2 class="text-center">
    @ViewBag.TenNXB
</h2>
<h2 class="text-center">SÁCH THEO NHÀ XUẤT BẢN</h2>

<div class="row text-center">
    @foreach (var sach in Model)
    {
        <div class="col-sm-4 col-md-4 col-lg-4 col-xs-6">
            <div class="thumbnail">
                <a href="@Url.Action("ChiTietSach", "SachOnline", new { id = sach.MaSach })">
                    <img src="~/Images/@sach.AnhBia"
                         alt="@sach.TenSach"
                         class="imgbook" />
                </a>

                <div class="caption">
                    <h4>
                        <a href="@Url.Action("ChiTietSach", "SachOnline", new { id = sach.MaSach })">
                            @sach.TenSach
                        </a>
                    </h4>

                    <p>
                        <a href="@Url.Action("ThemGioHang", "GioHang", new { ms = sach.MaSach, url = Request.Url.ToString() })"
                           class="btn btn-primary">
                            Add to Cart
                        </a>
                    </p>
                </div>
            </div>
        </div>
    }
</div>