@{
    Layout = null;
    ViewBag.Title = "Login Admin";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Login Admin</title>

    <style>
        body {
            margin: 0;
            padding: 0;
            background: #f2f2f2;
            font-family: Arial, sans-serif;
        }

        .login-box {
            width: 360px;
            margin: 120px auto;
            padding: 30px;
            background: white;
            border-radius: 8px;
            box-shadow: 0 0 12px rgba(0,0,0,0.2);
        }

            .login-box h2 {
                text-align: center;
                margin-bottom: 25px;
                color: #333;
            }

            .login-box label {
                font-weight: bold;
                margin-top: 10px;
                display: block;
            }

            .login-box input[type="text"],
            .login-box input[type="password"] {
                width: 100%;
                padding: 10px;
                margin-top: 6px;
                margin-bottom: 15px;
                border: 1px solid #ccc;
                border-radius: 4px;
                box-sizing: border-box;
            }

            .login-box .btn-login {
                width: 100%;
                padding: 10px;
                background: #222;
                color: white;
                border: none;
                border-radius: 4px;
                font-weight: bold;
                cursor: pointer;
            }

                .login-box .btn-login:hover {
                    background: #444;
                }

        .message {
            color: red;
            text-align: center;
            font-style: italic;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>
    <div class="login-box">
        <h2>LOGIN ADMIN</h2>

        <form action="@Url.Action("Login", "Home", new { area = "Admin" })" method="post">
            <label>Username</label>
            <input type="text" name="UserName" placeholder="Nhập tên đăng nhập" required />

            <label>Password</label>
            <input type="password" name="Password" placeholder="Nhập mật khẩu" required />

            <p class="message">@ViewBag.ThongBao</p>

            <input type="submit" value="Đăng nhập" class="btn-login" />
        </form>
    </div>
</body>
</html>