@using TranVanCuong.SachOnline.Models
@{
    ADMIN admin = Session["Admin"] as ADMIN;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title - SachOnline Admin</title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins',sans-serif;
        }

        body {
            background: #f5f7fb;
            overflow-x: hidden;
        }

        .wrapper {
            display: flex;
            min-height: 100vh;
        }

        /*================ SIDEBAR ================*/

        .sidebar {
            width: 260px;
            background: #111827;
            color: #fff;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            overflow-y: auto;
        }

        .logo {
            height: 70px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 22px;
            font-weight: 700;
            border-bottom: 1px solid rgba(255,255,255,.08);
        }

            .logo a {
                color: white;
                text-decoration: none;
            }

        .menu {
            padding: 20px 0;
        }

        .menu-title {
            padding: 12px 25px;
            font-size: 12px;
            text-transform: uppercase;
            color: #94a3b8;
            letter-spacing: 1px;
        }

        .menu ul {
            list-style: none;
        }

        .menu li {
            margin: 4px 10px;
        }

            .menu li a {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 13px 18px;
                border-radius: 10px;
                color: #d1d5db;
                text-decoration: none;
                transition: .25s;
                font-weight: 500;
            }

                .menu li a:hover {
                    background: #2563eb;
                    color: white;
                }

        /*================ CONTENT ================*/

        .content {
            margin-left: 260px;
            width: calc(100% - 260px);
            min-height: 100vh;
        }

        /*================ HEADER ================*/

        .topbar {
            height: 70px;
            background: white;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 35px;
            box-shadow: 0 2px 10px rgba(0,0,0,.05);
        }

            .topbar h3 {
                margin: 0;
                font-weight: 600;
                color: #111827;
            }

        .admin-info {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: #2563eb;
            color: white;
            display: flex;
            justify-content: center;
            align-items: center;
            font-weight: bold;
            font-size: 18px;
        }

        .admin-name {
            font-size: 15px;
        }

            .admin-name span {
                display: block;
                color: #6b7280;
                font-size: 13px;
            }

        .page-content {
            padding: 30px;
        }

        .content-card {
            background: white;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 5px 20px rgba(0,0,0,.05);
            min-height: 600px;
        }

        footer {
            padding: 20px;
            text-align: center;
            color: #6b7280;
            font-size: 13px;
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <!-- ================= SIDEBAR ================= -->

        <div class="sidebar">

            <div class="logo">
                <a href="@Url.Action("Index","Home",new { area="Admin"})">
                    📚 SachOnline
                </a>
            </div>

            <div class="menu">

                <div class="menu-title">
                    TỔNG QUAN
                </div>

                <ul>

                    <li>
                        <a href="@Url.Action("Index","Home",new { area="Admin"})">
                            <span class="glyphicon glyphicon-home"></span>
                            Dashboard
                        </a>
                    </li>

                </ul>

                <div class="menu-title">
                    QUẢN LÝ
                </div>

                <ul>

                    <li>
                        <a href="@Url.Action("Index","Sach",new { area="Admin"})">
                            <span class="glyphicon glyphicon-book"></span>
                            Quản lý sách
                        </a>
                    </li>

                    <li>
                        <a href="#">
                            <span class="glyphicon glyphicon-th-list"></span>
                            Chủ đề
                        </a>
                    </li>

                    <li>
                        <a href="#">
                            <span class="glyphicon glyphicon-briefcase"></span>
                            Nhà xuất bản
                        </a>
                    </li>

                    <li>
                        <a href="#">
                            <span class="glyphicon glyphicon-user"></span>
                            Khách hàng
                        </a>
                    </li>

                    <li>
                        <a href="#">
                            <span class="glyphicon glyphicon-shopping-cart"></span>
                            Đơn hàng
                        </a>
                    </li>

                </ul>

                <div class="menu-title">
                    HỆ THỐNG
                </div>

                <ul>

                    <li>
                        <a href="#">
                            <span class="glyphicon glyphicon-cog"></span>
                            Cài đặt
                        </a>
                    </li>

                    <li>
                        <a href="@Url.Action("Logout","Home",new { area="Admin"})">
                            <span class="glyphicon glyphicon-log-out"></span>
                            Đăng xuất
                        </a>
                    </li>

                </ul>

            </div>

        </div>

        <!-- ================= CONTENT ================= -->

        <div class="content">

            <div class="topbar">

                <h3>@ViewBag.Title</h3>

                <div class="admin-info">

                    <div class="admin-name">

                        <strong>
                            Xin chào,
                            @(admin != null ? admin.TenDN : "Administrator")
                        </strong>

                        <span>
                            Quản trị viên
                        </span>

                    </div>

                    <div class="avatar">

                        @if (admin != null)
                        {
                            @admin.TenDN.Substring(0, 1).ToUpper()
                        }
                        else
                        {
                            @:A
                        }

                    </div>

                </div>

            </div>

            <div class="page-content">

                <div class="content-card">

                    @RenderBody()

                </div>

            </div>

            <footer>

                © @DateTime.Now.Year - SachOnline Admin Dashboard

            </footer>

        </div>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")

</body>
</html>